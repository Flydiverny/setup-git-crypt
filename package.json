{
  "name": "setup-git-crypt",
  "version": "5.0.0",
  "private": true,
  "description": "TypeScript template action",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "all": "npm run build && npm run format && npm run lint && npm run package && echo",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flydiverny/setup-git-crypt.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@typescript-eslint/typescript-estree": "^8.25.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "eslint-plugin-github": "^5.1.8",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "prettier": "^3.5.2",
    "typescript": "^5.7.2"
  }
}
